<article class="product-card">
  <div class="product-img"><%= product.category ? product.category.name : 'Producto' %></div>
  <h3><%= product.name %></h3>
  <p class="muted"><%= product.brand ? product.brand.name : 'Marca' %> | <%= product.description.substring(0, 80) %>...</p>
  <p class="price">$<%= Number(product.price).toLocaleString('es-AR') %></p>
  <div class="card-actions">
    <a class="btn" href="/products/<%= product.id %>">Ver producto</a>
    <a class="btn btn-outline" href="/products/<%= product.id %>/edit">Editar</a>
  </div>
</article>
