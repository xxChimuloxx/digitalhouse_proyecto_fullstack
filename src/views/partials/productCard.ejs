<article class="product-card">
  <div class="product-img"><%= product.category %></div>
  <h3><%= product.name %></h3>
  <p class="muted"><%= product.description %></p>
  <p class="price">$<%= product.price.toLocaleString('es-AR') %></p>
  <div class="card-actions">
    <a class="btn" href="/products/<%= product.id %>">Ver producto</a>
    <a class="btn btn-outline" href="/products/<%= product.id %>/edit">Editar</a>
  </div>
</article>
