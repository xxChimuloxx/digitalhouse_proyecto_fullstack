<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="section">
    <div class="container detail-layout">
      <div class="detail-img">Imagen del producto</div>
      <section class="panel">
        <p class="muted">Inicio / Productos / <%= product.category %></p>
        <h1><%= product.name %></h1>
        <p class="price">$<%= product.price.toLocaleString('es-AR') %></p>
        <p><%= product.description %></p>

        <ul class="features">
          <li>Categoría: <%= product.category %></li>
          <li>Color: <%= product.color %></li>
          <li>Garantía oficial</li>
          <li>Entrega a domicilio o retiro en sucursal</li>
        </ul>

        <div class="detail-actions">
          <a class="btn btn-secondary" href="/cart">Agregar al carrito</a>
          <a class="btn btn-outline" href="/products/edit/<%= product.id %>">Editar producto</a>
        </div>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
