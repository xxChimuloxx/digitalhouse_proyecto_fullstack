<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="section">
    <div class="container narrow">
      <section class="form-card">
        <h1>Crear producto</h1>
        <p class="muted">Formulario funcional para agregar productos en MySQL usando Sequelize.</p>
        <% if (Object.keys(errors || {}).length) { %>
          <div class="alert-error">Revisá los campos marcados antes de guardar el producto.</div>
        <% } %>
        <form action="/products" method="POST" class="validate-product" novalidate>
          <label>Nombre del producto
            <input type="text" name="name" value="<%= oldData.name || '' %>" placeholder="Ej: Teclado mecánico RGB">
            <% if (errors.name) { %><small class="form-error"><%= errors.name.msg %></small><% } %>
          </label>
          <label>Descripción
            <textarea name="description" rows="4"><%= oldData.description || '' %></textarea>
            <% if (errors.description) { %><small class="form-error"><%= errors.description.msg %></small><% } %>
          </label>
          <label>Imagen
            <input type="text" name="image" value="<%= oldData.image || '' %>" placeholder="product-default.png">
            <% if (errors.image) { %><small class="form-error"><%= errors.image.msg %></small><% } %>
          </label>
          <label>Categoría
            <select name="category_id">
              <option value="">Seleccionar categoría</option>
              <% categories.forEach(category => { %>
                <option value="<%= category.id %>" <%= Number(oldData.category_id) === Number(category.id) ? 'selected' : '' %>><%= category.name %></option>
              <% }) %>
            </select>
            <% if (errors.category_id) { %><small class="form-error"><%= errors.category_id.msg %></small><% } %>
          </label>
          <label>Marca
            <select name="brand_id">
              <option value="">Seleccionar marca</option>
              <% brands.forEach(brand => { %>
                <option value="<%= brand.id %>" <%= Number(oldData.brand_id) === Number(brand.id) ? 'selected' : '' %>><%= brand.name %></option>
              <% }) %>
            </select>
            <% if (errors.brand_id) { %><small class="form-error"><%= errors.brand_id.msg %></small><% } %>
          </label>
          <label>Colores
            <select name="colors" multiple>
              <% colors.forEach(color => { %>
                <option value="<%= color.id %>" <%= selectedColors.includes(color.id) ? 'selected' : '' %>><%= color.name %></option>
              <% }) %>
            </select>
            <% if (errors.colors) { %><small class="form-error"><%= errors.colors.msg %></small><% } %>
          </label>
          <label>Precio
            <input type="number" name="price" value="<%= oldData.price || '' %>" placeholder="89999">
            <% if (errors.price) { %><small class="form-error"><%= errors.price.msg %></small><% } %>
          </label>
          <label class="checkbox-line">
            <input type="checkbox" name="featured" <%= oldData.featured ? 'checked' : '' %>>
            Mostrar como producto destacado
          </label>
          <button class="btn btn-secondary" type="submit">Guardar producto</button>
        </form>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <script src="/js/productValidation.js"></script>
</body>
</html>
