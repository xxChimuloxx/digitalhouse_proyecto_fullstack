<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="section">
    <div class="container narrow">
      <section class="form-card">
        <h1>Crear producto</h1>
        <p class="muted">Formulario funcional para agregar productos en MySQL usando Sequelize.</p>
        <form action="/products" method="POST">
          <label>Nombre del producto
            <input type="text" name="name" placeholder="Ej: Teclado mecánico RGB" required>
          </label>
          <label>Descripción
            <textarea name="description" rows="4" required></textarea>
          </label>
          <label>Imagen
            <input type="text" name="image" placeholder="product-default.png">
          </label>
          <label>Categoría
            <select name="category_id" required>
              <% categories.forEach(category => { %>
                <option value="<%= category.id %>"><%= category.name %></option>
              <% }) %>
            </select>
          </label>
          <label>Marca
            <select name="brand_id" required>
              <% brands.forEach(brand => { %>
                <option value="<%= brand.id %>"><%= brand.name %></option>
              <% }) %>
            </select>
          </label>
          <label>Colores
            <select name="colors" multiple>
              <% colors.forEach(color => { %>
                <option value="<%= color.id %>"><%= color.name %></option>
              <% }) %>
            </select>
          </label>
          <label>Precio
            <input type="number" name="price" placeholder="89999" required>
          </label>
          <label class="checkbox-line">
            <input type="checkbox" name="featured">
            Mostrar como producto destacado
          </label>
          <button class="btn btn-secondary" type="submit">Guardar producto</button>
        </form>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
