<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="section">
    <div class="container narrow">
      <section class="form-card">
        <h1>Crear producto</h1>
        <p class="muted">Formulario funcional para agregar nuevos productos al archivo JSON.</p>
        <form action="/products" method="POST">
          <label>Nombre del producto
            <input type="text" name="name" placeholder="Ej: Teclado mecánico RGB" required>
          </label>
          <label>Descripción
            <textarea name="description" rows="4" placeholder="Descripción breve del producto" required></textarea>
          </label>
          <label>Imagen
            <input type="text" name="image" placeholder="producto-generico.png">
          </label>
          <label>Categoría
            <select name="category" required>
              <option value="Periféricos">Periféricos</option>
              <option value="Audio">Audio</option>
              <option value="Monitores">Monitores</option>
              <option value="PC y componentes">PC y componentes</option>
              <option value="Sillas">Sillas</option>
              <option value="Streaming">Streaming</option>
            </select>
          </label>
          <label>Colores
            <input type="text" name="colors" placeholder="Negro, azul, violeta">
          </label>
          <label>Precio
            <input type="number" name="price" placeholder="89999" required>
          </label>
          <label class="checkbox-line">
            <input type="checkbox" name="featured">
            Mostrar como producto destacado
          </label>
          <button class="btn btn-secondary" type="submit">Guardar producto</button>
        </form>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
