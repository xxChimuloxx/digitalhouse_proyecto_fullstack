<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="section">
    <div class="container narrow">
      <section class="form-card">
        <h1>Editar producto</h1>
        <p class="muted">Formulario funcional para modificar productos existentes en el archivo JSON.</p>
        <form action="/products/<%= product.id %>?_method=PUT" method="POST">
          <label>Nombre del producto
            <input type="text" name="name" value="<%= product.name %>" required>
          </label>
          <label>Descripción
            <textarea name="description" rows="4" required><%= product.description %></textarea>
          </label>
          <label>Imagen
            <input type="text" name="image" value="<%= product.image %>">
          </label>
          <label>Categoría
            <input type="text" name="category" value="<%= product.category %>" required>
          </label>
          <label>Colores
            <input type="text" name="colors" value="<%= product.colors ? product.colors.join(', ') : '' %>">
          </label>
          <label>Precio
            <input type="number" name="price" value="<%= product.price %>" required>
          </label>
          <label class="checkbox-line">
            <input type="checkbox" name="featured" <%= product.featured ? 'checked' : '' %>>
            Mostrar como producto destacado
          </label>
          <button class="btn btn-secondary" type="submit">Actualizar producto</button>
        </form>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
