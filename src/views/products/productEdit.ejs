<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="section">
    <div class="container narrow">
      <section class="form-card">
        <h1>Editar producto</h1>
        <p class="muted">Formulario funcional para actualizar productos en MySQL usando Sequelize.</p>
        <form action="/products/<%= product.id %>?_method=PUT" method="POST">
          <label>Nombre del producto
            <input type="text" name="name" value="<%= product.name %>" required>
          </label>
          <label>Descripción
            <textarea name="description" rows="4" required><%= product.description %></textarea>
          </label>
          <label>Imagen
            <input type="text" name="image" value="<%= product.image %>">
          </label>
          <label>Categoría
            <select name="category_id" required>
              <% categories.forEach(category => { %>
                <option value="<%= category.id %>" <%= Number(product.category_id) === Number(category.id) ? 'selected' : '' %>><%= category.name %></option>
              <% }) %>
            </select>
          </label>
          <label>Marca
            <select name="brand_id" required>
              <% brands.forEach(brand => { %>
                <option value="<%= brand.id %>" <%= Number(product.brand_id) === Number(brand.id) ? 'selected' : '' %>><%= brand.name %></option>
              <% }) %>
            </select>
          </label>
          <label>Colores
            <select name="colors" multiple>
              <% colors.forEach(color => { %>
                <option value="<%= color.id %>" <%= selectedColors.includes(color.id) ? 'selected' : '' %>><%= color.name %></option>
              <% }) %>
            </select>
          </label>
          <label>Precio
            <input type="number" name="price" value="<%= Number(product.price) %>" required>
          </label>
          <label class="checkbox-line">
            <input type="checkbox" name="featured" <%= product.featured ? 'checked' : '' %>>
            Mostrar como producto destacado
          </label>
          <button class="btn btn-secondary" type="submit">Actualizar producto</button>
        </form>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
