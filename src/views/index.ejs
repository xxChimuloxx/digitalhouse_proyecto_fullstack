<!DOCTYPE html>
<html lang="es">
<%- include('partials/head') %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Marketplace gamer y tecnología</p>
          <h1>Armá tu setup gamer ideal</h1>
          <p>Periféricos, componentes y accesorios seleccionados para jugadores, streamers, estudiantes y usuarios que buscan mejorar su experiencia digital.</p>
          <a class="btn btn-secondary" href="/products">Ver productos</a>
        </div>
        <aside class="hero-card">
          <strong>Oferta destacada</strong>
          <p class="muted">Combos de teclado, mouse y auriculares para comenzar a jugar con estilo.</p>
        </aside>
      </div>
    </section>

    <section class="section" id="productos">
      <div class="container">
        <div class="section-head">
          <h2 class="section-title">Productos destacados</h2>
          <a href="/products" class="link-action">Ver todos</a>
        </div>
        <div class="product-grid">
          <% products.forEach(product => { %>
            <%- include('partials/productCard', { product }) %>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container">
        <h2 class="section-title">Categorías</h2>
        <div class="category-grid">
          <% categories.forEach(category => { %>
            <a class="category-card" href="/products"><%= category %></a>
          <% }) %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
