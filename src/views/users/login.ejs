<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="auth-page">
    <section class="auth-card">
      <h1>Iniciar sesión</h1>
      <p>Ingresá con tu usuario para acceder a tu perfil e historial de compras.</p>

      <% if (error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form action="/users/login" method="POST" class="form-grid">
        <label>Email
          <input type="email" name="email" placeholder="usuario@email.com" required>
        </label>
        <label>Contraseña
          <input type="password" name="password" placeholder="Tu contraseña" required>
        </label>
        <label class="checkbox-line">
          <input type="checkbox" name="remember">
          Recordarme en este equipo
        </label>
        <button class="btn-primary" type="submit">Ingresar</button>
      </form>

      <p class="auth-link"><a href="#">¿Olvidaste tu contraseña?</a></p>
      <p class="auth-link">¿No tenés cuenta? <a href="/users/register">Crear cuenta</a></p>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
