<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="section auth-section">
    <div class="container narrow">
      <section class="form-card">
        <h1>Iniciar sesión</h1>
        <p class="muted">Ingresá para consultar tu perfil e historial de compras.</p>
        <form>
          <label>Email
            <input type="email" placeholder="ejemplo@email.com">
          </label>
          <label>Contraseña
            <input type="password" placeholder="********">
          </label>
          <label class="checkbox-line">
            <input type="checkbox"> Recordarme
          </label>
          <p class="form-error">Ejemplo de error visual: usuario o contraseña incorrectos.</p>
          <button class="btn btn-secondary" type="button">Ingresar</button>
        </form>
        <p class="auth-link"><a href="#">¿Olvidaste tu contraseña?</a></p>
        <p class="auth-link">¿No tenés cuenta? <a href="/users/register">Crear cuenta</a></p>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
