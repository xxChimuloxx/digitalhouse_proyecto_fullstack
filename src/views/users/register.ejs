<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="auth-page">
    <section class="auth-card">
      <h1>Crear cuenta</h1>
      <p>Registrate para comprar más rápido y acceder a tu perfil.</p>

      <% if (error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form action="/users/register" method="POST" enctype="multipart/form-data" class="form-grid">
        <label>Nombre
          <input type="text" name="firstName" value="<%= oldData.firstName || '' %>" placeholder="Sebastián" required>
        </label>
        <label>Apellido
          <input type="text" name="lastName" value="<%= oldData.lastName || '' %>" placeholder="Fuentes" required>
        </label>
        <label>Email
          <input type="email" name="email" value="<%= oldData.email || '' %>" placeholder="usuario@email.com" required>
        </label>
        <label>Contraseña
          <input type="password" name="password" placeholder="Mínimo 6 caracteres" required>
        </label>
        <label>Confirmar contraseña
          <input type="password" name="confirmPassword" placeholder="Repetí tu contraseña" required>
        </label>
        <label>Imagen de perfil
          <input type="file" name="image" accept="image/*">
        </label>
        <button class="btn-primary" type="submit">Crear cuenta</button>
      </form>

      <p class="auth-link">¿Ya tenés cuenta? <a href="/users/login">Iniciar sesión</a></p>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
