<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>
  <main class="section">
    <div class="container">
      <h1 class="section-title">Usuarios</h1>
      <p class="muted">Listado de usuarios obtenido desde MySQL con Sequelize.</p>
      <div class="table-card">
        <% users.forEach(user => { %>
          <div class="table-row">
            <span><strong><%= user.firstName %> <%= user.lastName %></strong></span>
            <span><%= user.email %></span>
            <span><%= user.category %></span>
            <a class="btn btn-outline" href="/users/<%= user.id %>">Ver</a>
          </div>
        <% }) %>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
